# Copy this file to .env and fill in your own values.
# NEVER commit .env to Git.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Stripe (optional — app falls back to trial mode without these)
VITE_STRIPE_PUBLISHABLE_KEY=""

# Dev-only: when "true" AND `npm run dev`, unlocks all plan features locally. Never set "true" for production builds.
VITE_DEV_UNLOCK_ALL_FEATURES="false"

# Platform admin: comma-separated emails allowed to use /platform-admin. If empty, no one is a platform admin (fail closed).
VITE_PLATFORM_ADMIN_EMAILS=""

# Support & FAQ (/support): optional mailto recipient override (default in app: spigelai@gmail.com)
# VITE_SUPPORT_EMAIL="support@your-domain.com"

# Optional: browser error tracking (leave empty to disable)
# VITE_SENTRY_DSN=""

# Optional: canonical origin for public club SEO (Open Graph URLs, JSON-LD). Defaults to window.location.origin.
# Also used by /api/club-social-preview for WhatsApp and social link previews.
# VITE_PUBLIC_SITE_URL="https://your-app.example.com"

# ---------------------------------------------------------------------------
# Supabase Edge Functions — set in Supabase Dashboard → Edge Functions → Secrets
#
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
# EDGE_ALLOWED_ORIGINS=https://your-app.example.com,http://localhost:8080
#
# Club member invite emails (send-club-invite-email):
#   RESEND_API_KEY=re_...
#   RESEND_FROM_EMAIL="ONE4Team <invites@your-verified-domain.com>"
#   PUBLIC_SITE_URL=https://your-app.example.com
# Then: supabase functions deploy send-club-invite-email
#
# Subscription checkout (stripe-checkout): map each plan × cycle to a Stripe Price id
# (Dashboard → Product → Price → API ID, starts with price_...).
#   STRIPE_PRICE_KICKOFF_YEARLY=price_...
#   STRIPE_PRICE_KICKOFF_MONTHLY=price_...
#   STRIPE_PRICE_SQUAD_YEARLY=price_...
#   STRIPE_PRICE_SQUAD_MONTHLY=price_...
#   STRIPE_PRICE_PRO_YEARLY=price_...
#   STRIPE_PRICE_PRO_MONTHLY=price_...
#   STRIPE_PRICE_CHAMPIONS_YEARLY=price_...
#   STRIPE_PRICE_CHAMPIONS_MONTHLY=price_...
# Local/sandbox only (unsafe for production):
#   STRIPE_ALLOW_PLACEHOLDER_PRICE_IDS=true
#
# Webhook (stripe-webhook): optional tuning for claim-first idempotency
#   STRIPE_WEBHOOK_STALE_CLAIM_MS=120000   # reclaim abandoned claims after this age (30s–600s)
#
# Optional platform LLM fallback when a club has NOT saved its own keys (AI 4 T / co-trainer):
# Set in Supabase Dashboard → Edge Functions → Secrets (NOT in this file):
#   supabase secrets set OPENAI_API_KEY="sk-..."
#   supabase secrets set OPENAI_MODEL="gpt-4o-mini"
# Then: supabase functions deploy co-trainer
# Verify: Settings → Club → AI provider → Test connection (admin). Full guide: DEPLOYMENT.md § AI 4 T.
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
