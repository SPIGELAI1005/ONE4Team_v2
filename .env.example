# Copy this file to .env and fill in your own values.
# NEVER commit .env to Git.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Stripe (optional — app falls back to trial mode without these)
VITE_STRIPE_PUBLISHABLE_KEY=""

# Dev/test mode — set to "true" to unlock all plan features without a subscription
VITE_DEV_UNLOCK_ALL_FEATURES="true"

# Platform admin — comma-separated emails that can access /platform-admin
VITE_PLATFORM_ADMIN_EMAILS="spigelai@gmail.com"

# ---------------------------------------------------------------------------
# Supabase Edge Functions — optional platform fallback when a club has NOT
# saved its own LLM keys (Settings → Club → AI provider). Do NOT use VITE_.
#
#   supabase secrets set OPENAI_API_KEY="sk-..."
#   supabase secrets set OPENAI_MODEL="gpt-4o-mini"
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
